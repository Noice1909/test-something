# ── LLM Configuration ──────────────────────────────────────────────
# Supported providers: "anthropic" | "openai" | "ollama"
AGENT_LLM_PROVIDER=anthropic
AGENT_LLM_MODEL=claude-sonnet-4-5-20250929
AGENT_LLM_API_KEY=your-api-key-here
# AGENT_LLM_BASE_URL=http://localhost:11434  # for Ollama or custom endpoints
AGENT_LLM_TEMPERATURE=0.0
AGENT_MAX_TOKENS=8192

# ── Ollama example (uncomment and comment out Anthropic above) ────
# AGENT_LLM_PROVIDER=ollama
# AGENT_LLM_MODEL=qwen2.5:latest
# AGENT_LLM_API_KEY=not-needed
# AGENT_LLM_BASE_URL=http://localhost:11434

# ── Neo4j Configuration ────────────────────────────────────────────
AGENT_NEO4J_URI=bolt://localhost:7687
AGENT_NEO4J_USER=neo4j
AGENT_NEO4J_PASSWORD=your-password
AGENT_NEO4J_DATABASE=neo4j
# Set to True for Neo4j Aura or self-signed certs (rewrites neo4j+s → neo4j+ssc)
AGENT_NEO4J_SKIP_TLS_VERIFY=True

# ── Agent Behavior ─────────────────────────────────────────────────
AGENT_MAX_TURNS=50
AGENT_MAX_CONTEXT_TOKENS=150000
AGENT_COMPACT_THRESHOLD=0.8

# ── Discovery ──────────────────────────────────────────────────────
AGENT_SKILLS_DIR=.skills
AGENT_AGENTS_DIR=.agents

# ── Hooks ──────────────────────────────────────────────────────────
# Directory for hook scripts (future: file-based hooks)
AGENT_HOOKS_DIR=.hooks

# ── Prompt Caching ─────────────────────────────────────────────────
# Caches system prompt in-memory + enables Anthropic prompt-caching header
AGENT_ENABLE_PROMPT_CACHE=True

# ── MCP Servers (JSON format) ──────────────────────────────────────
# AGENT_MCP_SERVERS={"neo4j": {"command": "python", "args": ["mcp_neo4j.py"]}}

# ── Server ─────────────────────────────────────────────────────────
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
