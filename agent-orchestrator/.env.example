# ── LLM Configuration ──────────────────────────────────────────────
AGENT_LLM_PROVIDER=anthropic
AGENT_LLM_MODEL=claude-sonnet-4-5-20250929
AGENT_LLM_API_KEY=your-api-key-here
# AGENT_LLM_BASE_URL=http://localhost:11434  # for Ollama or custom endpoints
AGENT_LLM_TEMPERATURE=0.0
AGENT_MAX_TOKENS=8192

# ── Neo4j Configuration ────────────────────────────────────────────
AGENT_NEO4J_URI=bolt://localhost:7687
AGENT_NEO4J_USER=neo4j
AGENT_NEO4J_PASSWORD=your-password
AGENT_NEO4J_DATABASE=neo4j

# ── Agent Behavior ─────────────────────────────────────────────────
AGENT_MAX_TURNS=50
AGENT_MAX_CONTEXT_TOKENS=150000
AGENT_COMPACT_THRESHOLD=0.8

# ── Discovery ──────────────────────────────────────────────────────
AGENT_SKILLS_DIR=.skills
AGENT_AGENTS_DIR=.agents

# ── MCP Servers (JSON format) ──────────────────────────────────────
# AGENT_MCP_SERVERS={"neo4j": {"command": "python", "args": ["mcp_neo4j.py"]}}

# ── Server ─────────────────────────────────────────────────────────
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
