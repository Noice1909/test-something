# ─── Agentic System ───
AGENTIC_SYSTEM_ENABLED=true
AGENTIC_MAX_ATTEMPTS=3

# ─── Neo4j Connection ───
NEO4J_URI=neo4j+s://your-host:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password
NEO4J_DATABASE=neo4j

# ─── LLM Configuration ───
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:latest

# Uncomment to use OpenAI instead of Ollama
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ─── Cache ───
CACHE_BACKEND=memory

# ─── Server ───
SERVER_HOST=0.0.0.0
SERVER_PORT=8001
